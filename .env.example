# ─── PAYMENT MODE ────────────────────────────────────────────────────────────
# Set to "demo" to bypass Razorpay (for client demos / local testing).
# Remove this line (or set to "live") when going to production.
NEXT_PUBLIC_PAYMENT_MODE=demo

# ─── Razorpay (fill these when you have an account) ──────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# ─── Email / SMTP (for sending receipts and enquiry notifications) ──────────
# Gmail example: create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=NVVF Admissions <your_smtp_username>

# Where contact-form enquiries are delivered (defaults to SMTP_USER if unset)
ENQUIRY_TO_EMAIL=ganeshcm9@gmail.com
